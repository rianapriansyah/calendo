# Vite (browser) — safe to expose
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy name (same value as “anon” / “public” key in Supabase dashboard):
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Vercel: Settings → Environment Variables → add the same keys for Production (and Preview if needed).
# Redeploy after saving. Without them, login fails with 401 Invalid API Key.

# Never put the service role key in Vite env. For Edge Functions, set secrets in the dashboard:
# Project Settings → Edge Functions → Secrets: SUPABASE_SERVICE_ROLE_KEY
# Or locally: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
